# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local nunca é commitado (está no .gitignore) — só este .env.example fica no repositório,
# e por isso NUNCA deve ter valores reais, só os nomes das variáveis.

# GoHighLevel / Agenzi — token de "Private Integration" da subconta
GHL_API_TOKEN=
GHL_LOCATION_ID=

# Preenchidos mais à frente, quando o site completo (com banco de dados) começar:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DEEPL_API_KEY=
