# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local nunca é commitado (está no .gitignore) — só este .env.example fica no repositório.

# GoHighLevel / Agenzi — webhook de entrada para leads do formulário
GHL_INBOUND_WEBHOOK_URL=

# GoHighLevel / Agenzi — token de "Private Integration" da subconta (para ações via API, não só receber leads)
GHL_API_TOKEN=

# Preenchidos mais à frente, quando o site completo (com banco de dados) começar:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DEEPL_API_KEY=
